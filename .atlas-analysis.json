  "keyFeatures": [
    "Design System Generator with 100 industry-specific reasoning rules",
    "67 UI styles from Glassmorphism to Brutalism",
    "96 color palettes for different industries",
    "57 curated font pairings with Google Fonts imports",
    "BM25 search engine for intelligent recommendations",
    "CLI tool for quick installation across 15+ AI platforms",
    "Support for 13 tech stacks including React, Vue, SwiftUI, Flutter",
    "Hierarchical design system persistence (Master + Overrides pattern)",
    "99 UX guidelines and best practices",
    "25 chart type recommendations for dashboards"
  ],
  "publicApiSurface": [
    "uipro init --ai <platform>",
    "uipro update",
    "uipro versions",
    "python3 scripts/search.py \"<query>\" --design-system",
    "python3 scripts/search.py \"<query>\" --domain <domain>",
    "python3 scripts/search.py \"<query>\" --stack <stack>",
    "python3 scripts/search.py \"<query>\" --design-system --persist",
